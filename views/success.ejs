<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Submission Successful</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>Submission Successful</h1>
      <p>Your information was submitted successfully. Below is the sanitized data we received:</p>

      <dl class="result">
        <dt>Full Name</dt>
        <dd><%= data.name %></dd>

        <dt>Email</dt>
        <dd><%= data.email %></dd>

        <dt>Age</dt>
        <dd><%= data.age %></dd>

        <dt>Phone</dt>
        <dd><%= data.phone ? data.phone : '—' %></dd>

        <dt>Biography</dt>
        <dd><%= data.bio ? data.bio : '—' %></dd>
      </dl>

      <p><a href="/">Submit another response</a></p>
    </main>
  </body>
</html>
